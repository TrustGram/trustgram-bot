# ── Telegram ──────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token
WEBAPP_URL=https://your-mini-app-url.com

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./trustgram.db

# ── Logging (Properties-driven) ────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT="%(asctime)s | %(levelname)-8s | %(name)s:%(funcName)s:%(lineno)d - %(message)s"
LOG_FILE_PATH=logs/trustgram.log
LOG_TO_FILE=true
LOG_TO_CONSOLE=true

# ── Docs access ────────────────────────────────────────────────
# Set to "production" on Render (or any live host) to gate /docs and /redoc.
# Leave as "development" locally — no key required.
ENVIRONMENT=development
# Secret passed via  X-Docs-Key  header to access the docs in production.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty on dev — key is only enforced when ENVIRONMENT=production.
DOCS_API_KEY=
